# ==============================================================
# Norm — .gitignore
# ==============================================================

# ── Credenciales y configuraciones sensibles ──────────────────
.env
.env.local
.env.production
*.key
*.pem
*.p12
# Firebase (opcional si usas local emulator)
# firebase.json

# ── Firmas Android ───────────────────────────────────────────
*.jks
*.keystore
key.properties
android/key.properties
android/app/key.properties
android/app/*.jks
android/app/*.keystore
android/signing/

# ── Directorios de compilación temporal ──────────────────────
build/
.dart_tool/
.idea/
.vscode/
*.iml
*.ipr
*.iws
.flutter-plugins
.flutter-plugins-dependencies
.packages
pubspec.lock

# ── Dependencias ─────────────────────────────────────────────
.pub/
.dart_tool/package_config.json

# ── Bases de datos locales (desarrollo) ──────────────────────
*.db
*.sqlite
*.sqlite3
*.isar
*.isar.lock
*.db-journal
*.db-wal
*.db-shm

# ── Logs y dumps ─────────────────────────────────────────────
*.log
*.log.*
*.trace
*.dmp
*.stackdump

# ── Sistema ──────────────────────────────────────────────────
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini

# ── Flutter / Dart ───────────────────────────────────────────
.dart_tool/
.pub-cache/
.packages
pubspec.lock
**/generated_plugin_registrant.dart

# ── Android Studio / IntelliJ ────────────────────────────────
*.iml
.idea/
.gradle/
local.properties

# ── Windows ──────────────────────────────────────────────────
*.exe
*.exe.config
*.dll
*.pdb
*.msi
*.mst
*.cab
*.nupkg

# ── Instaladores generados ───────────────────────────────────
installer/Output/
